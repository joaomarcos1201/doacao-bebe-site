# Exemplo de variável de ambiente para o frontend (Create React App)
# Defina esta variável no ambiente de produção para apontar para a API no Render
REACT_APP_API_URL=https://doacao-bebe-site.onrender.com

# Como usar:
# - Local: npm start (se não definido, usa http://localhost:7979)
# - Produção: crie um arquivo .env com o mesmo conteúdo (ou configure no host)
